{
  "name": "vcf-design-studio",
  "version": "5.0.0",
  "private": true,
  "description": "Dev-only manifest for VCF Design Studio. The shipped vcf-design-studio-v5.html remains build-free (React, Tailwind, Babel loaded from CDNs). This package.json exists solely to run the test suite and regenerate the HTML artifact.",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build-html": "node scripts/build-html.mjs",
    "verify-html": "node scripts/verify-html-sync.mjs",
    "verify-cell-map": "node scripts/verify-cell-map.mjs",
    "generate-fixtures": "node scripts/generate-fixtures.mjs",
    "test": "npm run verify-html && npm run verify-cell-map && npm run test:unit && npm run test:migration && npm run test:snapshot && npm run test:invariants",
    "test:unit": "vitest run tests/unit",
    "test:migration": "vitest run tests/migration",
    "test:snapshot": "vitest run tests/snapshot",
    "test:invariants": "vitest run tests/invariants",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.7",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vitest": "^4.1.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
